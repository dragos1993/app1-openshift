# Database Configuration
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=taskdb
DB_HOST=postgres
DB_PORT=5432

# Backend Configuration
PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
NODE_ENV=development

# Frontend Configuration
